<Entity name="$projectile_default">

	<VariableStorageComponent
		_tags="spread_nonrandom_degrees"
		value_int="0"
	></VariableStorageComponent>

	<Base file="mods/noiting_simulator/files/spells/_base.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="-0.5"
		></VelocityComponent>

		<ProjectileComponent 
			speed_min="50"
			speed_max="50"
			muzzle_flash_file="mods/noiting_simulator/files/spells/muzzle_flashes/flash_yellow_medium.xml"
			damage="0.6"
			><damage_by_type
				slice="0.32"
				healing="4.8"
			></damage_by_type>
			<config_explosion
				explosion_sprite="data/particles/explosion_008.xml"
			></config_explosion>
		</ProjectileComponent>

		<SpriteComponent
			image_file="mods/noiting_simulator/files/spells/gfx/burst.xml" 
		></SpriteComponent>

		<AudioComponent
			file="data/audio/Desktop/projectiles.bank"
			event_root="projectiles/bloomshot">
		</AudioComponent>
	</Base>

	<ParticleEmitterComponent
		_enabled="0"
		_tags="proj_enable"
		render_on_grid="1"
		cosmetic_force_create="1"
		count_min="1"
		count_max="1"
		custom_alpha="0.55"
		draw_as_long="0"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		emit_cosmetic_particles="1"
		emit_only_if_there_is_space="0"
		emit_real_particles="0"
		emitted_material_name="spark_yellow"
		fade_based_on_lifetime="1"
		fire_cells_dont_ignite_damagemodel="0"
		gravity.x="0"
		gravity.y="0"
		is_emitting="1"
		is_trail="1"
		lifetime_min="1"
		lifetime_max="1"
		particle_single_width="1"
		render_back="0"
		area_circle_sector_degrees="360"
		velocity_always_away_from_center="0"
		friction="0"
	></ParticleEmitterComponent>

</Entity>